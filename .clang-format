# Style for the smart-ring sensor manager.
#
# Derived from LLVM, tuned to match the hand-written house style already in
# tree so `clang-format` is a no-churn guard rather than a reformatting event:
#   - 4-space indent, no tabs
#   - function opening brace on its own line, control-flow braces cuddled
#     (Linux brace style)
#   - aligned consecutive declarations and assignments (the tables of
#     `uint16_t  count;` / `size_t   n = ...;` throughout the core)
#   - 90-column limit, matching the widest existing lines
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 90
BreakBeforeBraces: Linux
AlignConsecutiveDeclarations: true
AlignConsecutiveAssignments: true
AlignConsecutiveMacros: true
AlignTrailingComments: true
PointerAlignment: Right
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
KeepEmptyLinesAtTheStartOfBlocks: false
SpaceAfterCStyleCast: false
IncludeBlocks: Preserve
SortIncludes: false
